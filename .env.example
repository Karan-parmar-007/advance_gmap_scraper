# DataImpulse residential proxy credentials
DATAIMPULSE_LOGIN=your_login
DATAIMPULSE_PASSWORD=your_password
DATAIMPULSE_HOST=gw.dataimpulse.com
# Rotating port (used only when PROXY_MODE=rotating)
DATAIMPULSE_PORT=823
DATAIMPULSE_PROTOCOL=http

# Sticky session ports (DataImpulse binds one IP per port)
DATAIMPULSE_STICKY_PORT_MIN=10000
DATAIMPULSE_STICKY_PORT_MAX=20000

# Enable residential proxies by default
PROXY_ENABLED=true

# sticky = same IP for one ZIP's pagination (ports 10000-20000)
# rotating = new IP often (port 823)
PROXY_MODE=sticky

# Targeting level used for each Maps request.
# Options: country | state | city | zip
# country = default targeting (1x traffic)
# state/city/zip = Target Filters (2x traffic)
PROXY_TARGETING=country

# If a precise filter returns NO_RAY, fall back to broader filters.
PROXY_FALLBACK=true

# Also pin sticky sessions with sessid.<zip> in the username
PROXY_USE_SESSID=true
